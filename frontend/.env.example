# All variables are optional in development — the Vite dev server proxies
# /api and /ws to http://localhost:8080 (see vite.config.ts).

# Absolute base URL of the backend API. Leave empty to use same-origin paths.
VITE_API_BASE_URL=

# WebSocket URL of the realtime endpoint (RFC-005). Leave empty to derive it
# from the page origin: ws(s)://<host>/ws/websocket
VITE_WS_URL=
