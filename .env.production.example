# QuizChef production environment template.
# Copy to .env.production or configure these variables in the deployment platform.
# Never commit real secrets.

# --- Spring profile and server ---
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# --- PostgreSQL ---
# Example Railway internal URL:
# DB_URL=jdbc:postgresql://postgres.railway.internal:5432/railway
DB_URL=jdbc:postgresql://db.example.internal:5432/quizchef
DB_USERNAME=quizchef
DB_PASSWORD=replace-with-a-secure-database-password

# --- Authentication ---
# HMAC-SHA256 signing secret for JWTs, minimum 32 characters.
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ACCESS_TOKEN_TTL=PT15M
# Optional. Leave empty unless issued tokens should include an audience claim.
JWT_AUDIENCE=

# --- Browser access ---
# Comma-separated origins allowed to call the backend API directly.
CORS_ALLOWED_ORIGINS=https://quizchef.example.com

# --- Object storage ---
# Use an S3-compatible endpoint. Railway Object Storage or external MinIO/S3 both work.
MINIO_ENDPOINT=https://s3.example.com
MINIO_ACCESS_KEY=replace-with-object-storage-access-key
MINIO_SECRET_KEY=replace-with-object-storage-secret-key
MINIO_BUCKET=quizchef-media

# --- Frontend build-time configuration ---
# Empty values use same-origin API and WebSocket paths.
VITE_API_BASE_URL=https://api.quizchef.example.com
VITE_WS_URL=wss://api.quizchef.example.com/ws/websocket

# --- Production Compose host ports and optional image names ---
BACKEND_PORT=8080
FRONTEND_PORT=3000
FRONTEND_CONTAINER_PORT=8080
BACKEND_IMAGE=quizchef-backend:prod
FRONTEND_IMAGE=quizchef-frontend:prod
