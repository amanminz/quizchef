# QuizChef local environment configuration.
# Copy this file to .env and adjust values as needed.
# Every variable has a working local default, so .env is optional.

# --- PostgreSQL ---
POSTGRES_DB=quizchef
POSTGRES_USER=quizchef
POSTGRES_PASSWORD=quizchef
POSTGRES_PORT=5432

# --- MinIO ---
MINIO_ROOT_USER=quizchef
MINIO_ROOT_PASSWORD=quizchef-local
MINIO_BUCKET=quizchef-media
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Security ---
# HMAC-SHA256 signing secret for JWTs, minimum 32 characters.
JWT_SECRET=quizchef-local-development-secret-0001
# Comma-separated origins allowed to call the API cross-origin. No
# production default exists — a real deployment must set this explicitly.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Application ports (host side) ---
BACKEND_PORT=8080
FRONTEND_PORT=3000
