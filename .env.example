# QuizChef local environment configuration.
# Copy this file to .env and adjust values as needed.
# Every variable has a working local default, so .env is optional.

# --- PostgreSQL ---
POSTGRES_DB=quizchef
POSTGRES_USER=quizchef
POSTGRES_PASSWORD=quizchef
POSTGRES_PORT=5432

# --- MinIO ---
MINIO_ROOT_USER=quizchef
MINIO_ROOT_PASSWORD=quizchef-local
MINIO_BUCKET=quizchef-media
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Application ports (host side) ---
BACKEND_PORT=8080
FRONTEND_PORT=3000
